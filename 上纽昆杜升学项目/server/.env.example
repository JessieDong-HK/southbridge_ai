ANTHROPIC_API_KEY=your_key_here
ANTHROPIC_BASE_URL=https://api.anthropic.com
CLAUDE_API_STYLE=anthropic
ANTHROPIC_MODEL=your_available_claude_model
ANTHROPIC_MAX_TOKENS=8192
AI_TIMEOUT_MS=120000
AI_RETRY_COUNT=3
AI_RETRY_BASE_DELAY_MS=3000
AI_RETRY_MAX_DELAY_MS=60000

# AI post-processing is best-effort after the primary data has been saved.
# Keep it shorter than the main OCR call so uploads do not stay running forever.
POST_PROCESS_TIMEOUT_MS=60000
POST_PROCESS_RETRY_COUNT=0
ASSESSMENT_TIMEOUT_MS=90000
ASSESSMENT_RETRY_COUNT=1
ASSESSMENT_MAX_TOKENS=1600
TRANSCRIPT_AI_CHARS=3000
ASSESSMENT_TRANSCRIPT_CHARS=800
ANALYSIS_SUMMARY_CHARS=2400
ANALYSIS_PROGRESS_CHARS=1600
ANALYSIS_GLOBAL_CHARS=1200
CHAT_ANALYSIS_CHARS=8000

# Vision OCR uses an OpenAI-compatible chat/completions endpoint.
VISION_API_KEY=your_vision_key_here
VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VISION_MODEL=qwen-vl-plus
VISION_TIMEOUT_MS=120000
VISION_RETRY_COUNT=8
VISION_RETRY_BASE_DELAY_MS=15000
VISION_RETRY_MAX_DELAY_MS=120000

# Server keeps the original upload, but sends an optimized copy to Vision OCR.
OCR_IMAGE_MAX_WIDTH=900
OCR_IMAGE_JPEG_QUALITY=78
